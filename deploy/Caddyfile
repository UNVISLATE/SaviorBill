# Маршрутизация:
#   /media/*  — всё (отдача готовых файлов, presign S3, двухшаговая загрузка) идёт
#               в mediaworker: он сам отдаёт локальные файлы (fs) и presigned-URL (s3).
#   /internal — внутренний API billing, наружу закрыт.
#   всё прочее — billing.
{$DOMAIN:localhost} {
	encode zstd gzip

	handle /media/* {
		reverse_proxy mediaworker:8080
	}

	handle {
		reverse_proxy billing:8000
	}
}
