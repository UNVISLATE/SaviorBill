# SaviorBill — пример переменных окружения.
# Скопируйте в .env и заполните. Значения ниже — безопасные дефолты/плейсхолдеры.
#
# Два класса переменных:
#   * ПОСТОЯННЫЕ      — читаются приложением на каждом старте.
#   * РАЗОВЫЕ (seed)  — при первом запуске засеваются в таблицу settings,
#                       далее редактируются из админки и берутся из БД.

# !!! ПОСТОЯННЫЕ !!!

# Деплой
IMAGE_PREFIX=ghcr.io/unvislate/saviorbill
TAG=latest

# Приложение
HOST=0.0.0.0
PORT=8000
DEBUG=false
DOCS_ENABLED=true
# CORS для billing (CSV origin'ов, напр. https://admin.example.com,https://app.example.com).
# Пусто -> CORS-заголовки не отправляются (нужно только при обращении с другого домена).
CORS_ORIGINS=
# Доверенные прокси для X-Forwarded-For/-Proto
TRUSTED_PROXIES=*

# MEDIAWorker приложение
MEDIA_HOST=0.0.0.0
MEDIA_PORT=8001
MEDIA_DEBUG=false
MEDIA_DOCS_ENABLED=true
# mediaworker читает ту же переменную CORS_ORIGINS (общий .env на весь стек).

# Any
PUBLIC_URL=http://localhost:8000
MEDIA_PUBLIC_URL=http://localhost:8001

# Caddy
DOMAIN=localhost:8000
MEDIA_DOMAIN=localhost:8001

#  БД (PostgreSQL) 
DB_DRIVER=postgresql+asyncpg
DB_USER=saviorbill
DB_PASS=change-me
DB_PASS_FILE=
DB_HOST=db
DB_PORT=5432
DB_NAME=saviorbill

#  Valkey / Redis
VALKEY_HOST=valkey
VALKEY_PORT=6379
VALKEY_DB=0

#  Auth / JWT
JWT_SECRET=
JWT_SECRET_FILE=/keys/jwt.key
JWT_ALG=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
JWT_ISS=saviorbill

# СЕКРЕТЫ (не меняйте если не знаете что это)
# SECRETS_BACKEND: file | aws | gcp | azure | vault
SECRETS_BACKEND=file
SECRETS_PREFIX=saviorbill/

# file (по умолчанию)
SECRETS_KEY=
SECRETS_KEY_PATH=/keys/secret.key
SECRETS_AWS_REGION=
SECRETS_GCP_PROJECT=
SECRETS_AZURE_VAULT_URL=
SECRETS_VAULT_ADDR=
SECRETS_VAULT_TOKEN=
SECRETS_VAULT_MOUNT=secret

# Пути к данным
DATA_DIR=/app/data
LUA_SCRIPTS_DIR=/app/data/lua
EMAIL_TEMPLATES_DIR=/app/data/email

# LuaWorker (шина Redis Streams)
LUA_TASK_STREAM=lua:tasks
LUA_RESP_STREAM=lua:results
LUA_GROUP=luaworkers
LUA_CALL_TIMEOUT=30
LUA_SERVICE_TOKEN=
LUA_SERVICE_TOKEN_FILE=/keys/lua_service.token

# Billing-loop (планировщик истечений услуг и перепроверок платежей)
BILLING_LOOP_ENABLED=true
# Размер «окна» очереди: сколько ближайших задач держать наготове.
BILLING_QUEUE_WINDOW=100
# Максимальная пауза сна планировщика (сек)
BILLING_IDLE_SECONDS=30
# Через сколько секунд «висящего» pending-платежа ставить перепроверку.
BILLING_PAY_RECHECK_AFTER=900
# Интервал авто-перепроверок платежа (сек) и их предел.
BILLING_PAY_RECHECK_INTERVAL=300
BILLING_PAY_RECHECK_MAX=5
# Предел одновременно исполняемых задач за итерацию (backpressure).
BILLING_CONCURRENCY=4
# Dead-letter очередь и предел попыток исполнения задачи биллинга.
BILLING_QUEUE_DLQ=billing:queue:dead
BILLING_QUEUE_MAX_ATTEMPTS=5

# Хранилище файлов (медиа товаров, аватарки, иконки)
# STORAGE_BACKEND: fs (файловая система) | s3 (s3 совместимое хранилище)
STORAGE_BACKEND=fs
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_KEY=
S3_SECRET=
S3_PUBLIC_URL=

#  Кэш / TTL / лимиты 
SETTINGS_CACHE_TTL=300
# TTL кода подтверждения email и сброса пароля (сидится в settings: mail.code_ttl)
VERIFY_TOKEN_TTL=3600
OAUTH_STATE_TTL=600
LOG_ROW_LIMIT=1000000

#  Загрузка медиа (байты) 
MEDIA_SMALL_MAX_BYTES=1048576
# Лимит для аккаунтов с правом media.uploadlarge (по сути — админы): поднят
# по умолчанию с 50 MiB до 500 MiB, ужесточайте под свой диск при желании.
MEDIA_MAX_BYTES=524288000

#  Медиа-конвейер (сервис mediaworker)
# TTL статуса конвертации в Valkey и длительность бана IP при фейковом Content-Length.
MEDIA_STATUS_TTL=3600
MEDIA_BAN_SECONDS=180
# Удалять оригинал после конвертации (true) или хранить (false).
MEDIA_KEEP_ORIGINAL=false
# Пресеты качества ffmpeg: webp (0..100) и webm CRF (0..63, меньше = лучше).
MEDIA_WEBP_QUALITY=82
MEDIA_WEBM_CRF=33
# Мини-вариант (обрезанный квадрат минимального качества): сторона px и качество webp.
MEDIA_THUMB_SIZE=96
MEDIA_THUMB_QUALITY=40
# Лимит загрузок в час для обычных пользователей (без права media.uploadlarge).
MEDIA_UPLOADS_PER_HOUR=30
# Двухшаговая загрузка: TTL одноразового upload-token (сек), выдаётся на шаге 1.
MEDIA_UPLOAD_TOKEN_TTL=60
# Backpressure воркера: предел одновременно обрабатываемых медиа-задач.
MEDIA_TASK_CONCURRENCY=4
# Dead-letter очереди и пределы попыток для медиа-задач (воркер) и результатов (billing).
MEDIA_TASK_DLQ=media:tasks:dead
MEDIA_TASK_MAX_ATTEMPTS=5
MEDIA_RESULT_DLQ=media:results:dead
MEDIA_RESULT_MAX_ATTEMPTS=5

#  Наблюдаемость (Observability) 
# Экспорт метрик Prometheus на /metrics (billing/mediaworker). false — эндпоинт отсутствует.
METRICS_ENABLED=false
# Токен для доступа к /metrics (заголовок X-Metrics-Token). Основной способ закрыть
# /metrics от внешнего мира — реверс-прокси не проксирует его наружу (см.
# deploy/Caddyfile) — токен нужен только как доп. рубеж (например, для доступа к
# порту контейнера напрямую внутри внутренней сети). Пусто — токен не требуется.
METRICS_TOKEN=
# Трейсинг OpenTelemetry. false (по умолчанию) — трейсинг не инициализируется,
# нулевой оверхед. true — требует заданного OTLP-эндпоинта ниже.
OTEL_ENABLED=false
# OTLP-эндпоинт коллектора/Jaeger. grpc: host:4317 | http/protobuf: host:4318/v1/traces.
# Пример для Jaeger all-in-one (порт 4317): http://jaeger:4317
OTEL_EXPORTER_OTLP_ENDPOINT=
# Протокол экспорта спанов: grpc (по умолчанию) | http/protobuf.
OTEL_EXPORTER_OTLP_PROTOCOL=grpc
# Плейнтекст без TLS для grpc (по умолчанию true — коллектор во внутренней сети).
# В проде с TLS-коллектором — false.
OTEL_EXPORTER_OTLP_INSECURE=true
# Имя сервиса в трейсах (пусто — берётся имя приложения SaviorBill).
OTEL_SERVICE_NAME=

#  Rate limiting (Valkey) 
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_MAX=60
RATE_LIMIT_DEFAULT_WINDOW=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_MAIL_MAX=3
RATE_LIMIT_MAIL_WINDOW=3600

#  РАЗОВЫЕ (seed) 

#  SMTP (засевается в settings при первом запуске) 
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

#  Имена базовых ролей (используются только при первом запуске для имени
#  Role.name в БД — НЕ дублируются в settings: после инициализации роль уже
#  существует, значение из ENV больше не читается) 
ROLE_OWNER=owner
ROLE_ADMIN=admin
ROLE_MANAGER=manager
ROLE_SUPPORT=support
ROLE_USER=user
ROLE_BANNED=banned

#  Названия UI (засеваются в settings при первом запуске как ui.admin.name /
#  ui.client.name — далее редактируются только через админку, не через ENV) 
UI_ADMIN_NAME=Admin
UI_CLIENT_NAME=Client

#  Bootstrap owner (создаётся при первом запуске; в settings НЕ хранится) 
OWNER_LOGIN=owner
OWNER_PASS=owner
OWNER_EMAIL=owner@example.com
