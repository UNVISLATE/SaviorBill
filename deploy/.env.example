# ============================================================================
# SaviorBill — пример переменных окружения.
# Скопируйте в .env и заполните. Значения ниже — безопасные дефолты/плейсхолдеры.
#
# Два класса переменных:
#   * ПОСТОЯННЫЕ      — читаются приложением на каждом старте.
#   * РАЗОВЫЕ (seed)  — при первом запуске засеваются в таблицу settings,
#                       далее редактируются из админки и берутся из БД.
# ============================================================================

# ----------------------------- ПОСТОЯННЫЕ -----------------------------------

# --- Приложение ---
HOST=0.0.0.0
PORT=8000
DEBUG=false
# OpenAPI-документация billing (Swagger UI /docs, ReDoc /redoc, /openapi.json).
# true (по умолчанию) — включена; false — все три эндпоинта отдают 404.
DOCS_ENABLED=true

# --- БД (PostgreSQL) ---
DB_DRIVER=postgresql+asyncpg
DB_USER=aiosupport
# Пароль БД: прямое значение ИЛИ путь к файлу через DB_PASS_FILE (Docker secret),
# либо берётся из выбранного менеджера секретов (см. секцию «Секреты»).
DB_PASS=change-me
DB_PASS_FILE=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aiosupport

# --- Valkey / Redis ---
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_DB=0

# --- Auth / JWT ---
# JWT_SECRET — генерируемый секрет. Оставьте пустым: создастся и сохранится в
# файл JWT_SECRET_FILE (по умолчанию DATA_DIR/keys/jwt.key) или в менеджер секретов.
JWT_SECRET=
JWT_SECRET_FILE=
JWT_ALG=HS256
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=2592000
JWT_ISS=saviorbill

# ============================ СЕКРЕТЫ ============================
# Политика: секреты — внешние ресурсы (файлы или менеджер секретов). В ENV —
# только путь/координаты. Генерируемые секреты создаются один раз (если их ещё
# нет) и далее переиспользуются.
#
# SECRETS_BACKEND: file | aws | gcp | azure | vault
SECRETS_BACKEND=file
# Префикс имени секрета в облачном менеджере.
SECRETS_PREFIX=saviorbill/
#
# -- file (по умолчанию): каждый секрет в своём файле под DATA_DIR/keys --
# Ключ шифрования секретов в БД (Fernet). Пусто => DATA_DIR/keys/secret.key.
SECRETS_KEY=
SECRETS_KEY_PATH=
#
# -- aws (AWS Secrets Manager): credentials из стандартной цепочки AWS --
SECRETS_AWS_REGION=
# -- gcp (Google Secret Manager) --
SECRETS_GCP_PROJECT=
# -- azure (Azure Key Vault) --
SECRETS_AZURE_VAULT_URL=
# -- vault (HashiCorp Vault, KV v2) --
SECRETS_VAULT_ADDR=
SECRETS_VAULT_TOKEN=
SECRETS_VAULT_MOUNT=secret

# --- Публичный URL (редиректы OAuth, ссылки в письмах) ---
PUBLIC_URL=http://localhost:8000

# --- Монтируемая папка данных (lua-скрипты, ключи, загрузки) ---
DATA_DIR=data
# Необязательно — по умолчанию DATA_DIR/lua и DATA_DIR/email.
LUA_SCRIPTS_DIR=
EMAIL_TEMPLATES_DIR=

# --- LuaWorker (шина Redis Streams) ---
LUA_TASK_STREAM=lua:tasks
LUA_RESP_STREAM=lua:results
LUA_GROUP=luaworkers
LUA_CALL_TIMEOUT=30
# Сервисный токен LuaWorker — генерируемый секрет. Пусто => создастся в файл
# LUA_SERVICE_TOKEN_FILE (по умолчанию DATA_DIR/keys/lua_service.token).
LUA_SERVICE_TOKEN=
LUA_SERVICE_TOKEN_FILE=

# --- Billing-loop (планировщик истечений услуг и перепроверок платежей) ---
# Встроенный asyncio-планировщик. Очередь РАЗДЕЛЯЕМАЯ (Valkey sorted set): каждый
# инстанс засевает её и запускает диспетчер; «созревшие» задачи выбираются атомарно
# (ZRANGEBYSCORE+ZREM), поэтому распределённый лок больше не нужен.
BILLING_LOOP_ENABLED=true
# Размер «окна» очереди: сколько ближайших задач держать наготове.
BILLING_QUEUE_WINDOW=100
# Максимальная пауза сна планировщика (сек), даже если ближайшая задача далеко.
BILLING_IDLE_SECONDS=30
# Через сколько секунд «висящего» pending-платежа ставить перепроверку.
BILLING_PAY_RECHECK_AFTER=900
# Интервал авто-перепроверок платежа (сек) и их предел до статуса wait.
BILLING_PAY_RECHECK_INTERVAL=300
BILLING_PAY_RECHECK_MAX=5
# Предел одновременно исполняемых задач за итерацию (backpressure).
BILLING_CONCURRENCY=4
# Dead-letter очередь и предел попыток исполнения задачи биллинга.
BILLING_QUEUE_DLQ=billing:queue:dead
BILLING_QUEUE_MAX_ATTEMPTS=5

# --- Хранилище файлов (медиа товаров, аватарки, иконки) ---
# STORAGE_BACKEND: fs | s3
STORAGE_BACKEND=fs
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_KEY=
S3_SECRET=
S3_PUBLIC_URL=

# --- Домен и reverse-proxy (Caddy) ---
# Домен для авто-TLS и HTTP/2/3. localhost => локальный самоподписанный сертификат.
DOMAIN=localhost
MEDIA_DOMAIN=localhost

# --- Реестр образов (прод, deploy/docker-compose.yml) ---
# Откуда тянуть образы billing/luaworker/mediaworker и какой тег использовать.
IMAGE_PREFIX=ghcr.io/unvislate/saviorbill
TAG=latest

# --- Кэш / TTL / лимиты ---
SETTINGS_CACHE_TTL=300
# TTL кода подтверждения email и сброса пароля (сидится в settings: mail.code_ttl)
VERIFY_TOKEN_TTL=3600
OAUTH_STATE_TTL=600
LOG_ROW_LIMIT=1000000

# --- Загрузка медиа (байты) ---
MEDIA_SMALL_MAX_BYTES=1048576
MEDIA_MAX_BYTES=52428800

# --- Медиа-конвейер (сервис mediaworker) ---
# OpenAPI-документация mediaworker (Swagger UI /docs, ReDoc /redoc, /openapi.json).
# true (по умолчанию) — включена; false — эндпоинты доки отдают 404.
MEDIA_DOCS_ENABLED=true
# Публичный базовый URL mediaworker для ссылки на его доку в описании billing.
# Пусто => строится из DOMAIN (https), fallback — внутренний MEDIAWORKER_URL.
MEDIA_PUBLIC_URL=
# TTL статуса конвертации в Valkey и длительность бана IP при фейковом Content-Length.
MEDIA_STATUS_TTL=3600
MEDIA_BAN_SECONDS=180
# Удалять оригинал после конвертации (true) или хранить (false).
MEDIA_KEEP_ORIGINAL=false
# Пресеты качества ffmpeg: webp (0..100) и webm CRF (0..63, меньше = лучше).
MEDIA_WEBP_QUALITY=82
MEDIA_WEBM_CRF=33
# Мини-вариант (обрезанный квадрат минимального качества): сторона px и качество webp.
MEDIA_THUMB_SIZE=96
MEDIA_THUMB_QUALITY=40
# Лимит загрузок в час для обычных пользователей (без права media.uploadlarge).
MEDIA_UPLOADS_PER_HOUR=30
# Двухшаговая загрузка: TTL одноразового upload-token (сек), выдаётся на шаге 1.
MEDIA_UPLOAD_TOKEN_TTL=60
# Backpressure воркера: предел одновременно обрабатываемых медиа-задач.
MEDIA_TASK_CONCURRENCY=4
# Dead-letter очереди и пределы попыток для медиа-задач (воркер) и результатов (billing).
MEDIA_TASK_DLQ=media:tasks:dead
MEDIA_TASK_MAX_ATTEMPTS=5
MEDIA_RESULT_DLQ=media:results:dead
MEDIA_RESULT_MAX_ATTEMPTS=5

# --- Наблюдаемость (Observability) ---
# Экспорт метрик Prometheus на /metrics (billing). false — эндпоинт отсутствует.
METRICS_ENABLED=true
# Формат логов: text (по умолчанию) | json. Уровень — LOG_LEVEL (INFO по умолчанию).
LOG_FORMAT=text
LOG_LEVEL=INFO
# OTLP-эндпоинт трейсинга (OpenTelemetry). Пусто — трейсинг в no-op режиме.
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Rate limiting (Valkey) ---
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_MAX=60
RATE_LIMIT_DEFAULT_WINDOW=60
RATE_LIMIT_AUTH_MAX=10
RATE_LIMIT_AUTH_WINDOW=60
RATE_LIMIT_MAIL_MAX=3
RATE_LIMIT_MAIL_WINDOW=3600

# --------------------------- РАЗОВЫЕ (seed) ---------------------------------

# --- SMTP (засевается в settings при первом запуске) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_TLS=true

# --- Имена базовых ролей (засеваются в settings) ---
ROLE_OWNER=owner
ROLE_ADMIN=admin
ROLE_MANAGER=manager
ROLE_SUPPORT=support
ROLE_USER=user
ROLE_BANNED=banned

# --- Bootstrap owner (создаётся при первом запуске; в settings НЕ хранится) ---
OWNER_LOGIN=owner
OWNER_PASS=owner-change-me
OWNER_EMAIL=owner@example.test
